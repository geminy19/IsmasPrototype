<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ISMAS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="main-header">
        <div class="header-inner">
            <a asp-controller="Home" asp-action="Index" class="brand-logo">
                <img src="~/images/integral-logo.png" alt="Integral" />
            </a>

            @{
                var controller = ViewContext.RouteData.Values["controller"]?.ToString();
            }

            <nav class="top-nav">
                <a asp-controller="Home"
                   asp-action="Index"
                   class="@(controller == "Home" ? "active" : "")">
                    Начало
                </a>

                <a asp-controller="Students"
                   asp-action="Index"
                   class="@(controller == "Students" ? "active" : "")">
                    Студенти
                </a>

                <a asp-controller="Payments"
                   asp-action="Index"
                   class="@(controller == "Payments" ? "active" : "")">
                    Такси
                </a>

                <a asp-controller="WorkLists"
                   asp-action="Index"
                   class="@(controller == "WorkLists" ? "active" : "")">
                    Работни списъци
                </a>
            </nav>
        </div>
    </header>

    <main class="page-wrapper">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>